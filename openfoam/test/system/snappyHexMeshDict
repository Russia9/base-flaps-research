FoamFile { version 2.0; format ascii; class dictionary; object snappyHexMeshDict; }

castellatedMesh true;
snap            true;
addLayers       false;  // add later once mesh is working

geometry
{
    body.stl
    {
        type triSurfaceMesh;
        name body;
    }
};

castellatedMeshControls
{
    maxLocalCells   1000000;
    maxGlobalCells  2000000;
    minRefinementCells 10;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 3;
    resolveFeatureAngle 30;

    features
    (
        {
            file "body.eMesh";
            level 3;
        }
    );

    refinementSurfaces
    {
        body
        {
            level (4 5);  // min max refinement levels
        }
    }

    refinementRegions
    {
        // refine the wake behind the base
        body
        {
            mode inside;
            levels ((1E15 4));
        }
    }

    locationInMesh (0.4 0.05 0.0);  // point inside domain, outside body
                               // x=400mm = mid-cylinder, well away from axis
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch    3;
    tolerance       2.0;
    nSolveIter      30;
    nRelaxIter      5;
    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeaturesnap false;
}

addLayersControls
{
    relativeSizes   true;
    layers
    {
        body
        {
            nSurfaceLayers 5;
        }
    }
    expansionRatio      1.2;
    finalLayerThickness 0.3;
    minThickness        0.1;
    nGrow               0;
    featureAngle        60;
    nRelaxIter          3;
    nSmoothSurfaceNormals 1;
    nSmoothNormals      3;
    nSmoothThickness    10;
    nRelaxedIter        5;
}

meshQualityControls
{
    maxNonOrtho         65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave          80;
    minFlatness         0.5;
    minVol              1e-13;
    minTetQuality       1e-15;
    minArea             -1;
    minTwist            0.02;
    minDeterminant      0.001;
    minFaceWeight       0.05;
    minVolRatio         0.01;
    minTriangleTwist    -1;
    nSmoothScale        4;
    errorReduction      0.75;
}

writeFlags
(
    scalarLevels
);

mergeTolerance 1e-6;
