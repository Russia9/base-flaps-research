FoamFile { version 2.0; format ascii; class dictionary; object snappyHexMeshDict; }

castellatedMesh true;
snap            true;
addLayers       false;  // add later once mesh is working

geometry
{
    body.stl
    {
        type triSurfaceMesh;
        scale 0.001;  // STL is in mm; convert to m to match blockMesh
        name body;
    }

    refinementCylinder
    {
        type searchableCylinder;
        point1 (-0.20 0.0 0.0);
        point2 (2.00 0.0 0.0);
        radius 0.24;
    }

    nearBodyCylinder
    {
        type searchableCylinder;
        point1 (-0.10 0.0 0.0);
        point2 (1.20 0.0 0.0);
        radius 0.12;
    }
};

castellatedMeshControls
{
    maxLocalCells   3000000;
    maxGlobalCells  3000000;
    minRefinementCells 5;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 2;
    resolveFeatureAngle 30;

    features
    (
        {
            file "body.eMesh";
            level 4;
        }
    );

    refinementSurfaces
    {
        body
        {
            level (4 5);
        }
    }

    refinementRegions
    {
        // Broad refinement from upstream of the nose through 1.5L downstream.
        refinementCylinder
        {
            mode inside;
            levels ((1E15 1));
        }

        // Stronger nested refinement around the body and immediate wake.
        nearBodyCylinder
        {
            mode inside;
            levels ((1E15 2));
        }
    }

    locationInMesh (0.4 0.05 0.0);  // inside fluid, outside the 40 mm body radius
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch    3;
    tolerance       2.0;
    nSolveIter      30;
    nRelaxIter      5;
    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeaturesnap false;
}

addLayersControls
{
    relativeSizes   true;
    layers
    {
        body
        {
            nSurfaceLayers 5;
        }
    }
    expansionRatio      1.2;
    finalLayerThickness 0.3;
    minThickness        0.1;
    nGrow               0;
    featureAngle        60;
    nRelaxIter          3;
    nSmoothSurfaceNormals 1;
    nSmoothNormals      3;
    nSmoothThickness    10;
    nRelaxedIter        5;
}

meshQualityControls
{
    maxNonOrtho         65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave          80;
    minFlatness         0.5;
    minVol              1e-13;
    minTetQuality       1e-15;
    minArea             -1;
    minTwist            0.02;
    minDeterminant      0.001;
    minFaceWeight       0.05;
    minVolRatio         0.01;
    minTriangleTwist    -1;
    nSmoothScale        4;
    errorReduction      0.75;
}

writeFlags
(
    scalarLevels
);

mergeTolerance 1e-6;
