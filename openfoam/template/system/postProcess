// Function-object definitions included into controlDict's functions {} block.
// Freestream values are included at the controlDict root and referenced here.

forces
{
    type            forces;
    libs            (forces);
    patches         (body);
    writeControl    timeStep;
    writeInterval   1;
    log             no;
    CofR            (0 0 0);
    rho             rhoInf;
    rhoInf          $rhoInf;
}

// DEBUG: locate the cell where the mean flow detonates. Prints the min/max of
// each field and the coordinates where they occur to the log every time step.
// Remove (with the frequent writes in controlDict) before the production sweep.
minMaxValues
{
    type            fieldMinMax;
    libs            (fieldFunctionObjects);
    mode            magnitude;
    fields          (p T rho U);
    location        yes;
    writeControl    timeStep;
    writeInterval   1;
    log             yes;
}

MachNo
{
    type            MachNo;
    libs            (fieldFunctionObjects);
    writeControl    writeTime;
}

gradRho
{
    type            grad;
    libs            (fieldFunctionObjects);
    field           rho;
    writeControl    writeTime;
}

magGradRho
{
    type            mag;
    libs            (fieldFunctionObjects);
    field           grad(rho);
    result          schlieren;
    writeControl    writeTime;
}

gradP
{
    type            grad;
    libs            (fieldFunctionObjects);
    field           p;
    writeControl    writeTime;
}

magGradP
{
    type            mag;
    libs            (fieldFunctionObjects);
    field           grad(p);
    result          magGradP;
    writeControl    writeTime;
}

pressureCoeff
{
    type            pressure;
    libs            (fieldFunctionObjects);
    mode            staticCoeff;
    result          Cp;
    rhoInf          $rhoInf;
    pInf            $pInf;
    UInf            $UInf;
    writeControl    writeTime;
}
