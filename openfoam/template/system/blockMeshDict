FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale   0.001;

vertices
(
    // Axial extent: x = -160 mm (-2D) to 1600 mm (+10D behind the base)
    // Cylindrical farfield radius: 640 mm = 8D
    // O-grid core half-width: 320 mm = 4D
    // Circular boundary diagonal intercept: 640 / sqrt(2) = 452.548 mm

    // inlet plane (x = -160 mm)
    (-160 -320.000 -320.000)  // 0  inner SW
    (-160  320.000 -320.000)  // 1  inner SE
    (-160  320.000  320.000)  // 2  inner NE
    (-160 -320.000  320.000)  // 3  inner NW
    (-160 -452.548 -452.548)  // 4  outer SW
    (-160  452.548 -452.548)  // 5  outer SE
    (-160  452.548  452.548)  // 6  outer NE
    (-160 -452.548  452.548)  // 7  outer NW

    // outlet plane (x = 1600 mm)
    (1600 -320.000 -320.000)  // 8  inner SW
    (1600  320.000 -320.000)  // 9  inner SE
    (1600  320.000  320.000)  // 10 inner NE
    (1600 -320.000  320.000)  // 11 inner NW
    (1600 -452.548 -452.548)  // 12 outer SW
    (1600  452.548 -452.548)  // 13 outer SE
    (1600  452.548  452.548)  // 14 outer NE
    (1600 -452.548  452.548)  // 15 outer NW
);

blocks
(
    hex (0 8 9 1 3 11 10 2)
    (80 32 32)
    simpleGrading (1 1 1)

    hex (4 12 13 5 0 8 9 1)
    (80 32 16)
    simpleGrading (1 1 1)

    hex (1 9 13 5 2 10 14 6)
    (80 16 32)
    simpleGrading (1 1 1)

    hex (3 11 10 2 7 15 14 6)
    (80 32 16)
    simpleGrading (1 1 1)

    hex (4 12 8 0 7 15 11 3)
    (80 16 32)
    simpleGrading (1 1 1)
);

edges
(
    arc 7 6   (-160   0.000  640.000)
    arc 6 5   (-160 640.000    0.000)
    arc 4 5   (-160   0.000 -640.000)
    arc 4 7   (-160 -640.000    0.000)

    arc 15 14 (1600   0.000  640.000)
    arc 14 13 (1600 640.000    0.000)
    arc 12 13 (1600   0.000 -640.000)
    arc 12 15 (1600 -640.000    0.000)
);

boundary
(
    inlet
    {
        type patch;
        faces
        (
            (0 3 2 1)
            (4 0 1 5)
            (1 2 6 5)
            (3 7 6 2)
            (4 7 3 0)
        );
    }
    outlet
    {
        type patch;
        faces
        (
            (8 9 10 11)
            (12 13 9 8)
            (9 13 14 10)
            (11 10 14 15)
            (12 8 11 15)
        );
    }
    farfield
    {
        type patch;
        faces
        (
            (7 15 14 6)
            (6 14 13 5)
            (4 5 13 12)
            (4 12 15 7)
        );
    }
);

mergePatchPairs
(
