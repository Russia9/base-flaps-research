FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     hisa;

// HiSA is a steady-state pseudo-transient solver: "time" is the outer
// (pseudo-time) iteration counter, not physical seconds. endTime is the
// iteration budget; deltaT is fixed at 1. Local time-stepping and the
// pseudo-CFL ramp live in fvSolution, so adjustTimeStep/maxCo are gone.
startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5000;

deltaT          1;

writeControl    timeStep;

writeInterval   100;

purgeWrite      2;

writeFormat     binary;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   6;

graphFormat     raw;

runTimeModifiable true;

#include "../constant/freestreamProperties"

functions
{
    #include "postProcess"
}


