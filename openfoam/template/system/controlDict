FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     rhoCentralFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.2;

deltaT          1e-08;

// DEBUG: the run dies at t~1.6e-5 s, long before the production 0.02 s
// interval, so nothing was ever written. Capture the field approaching the
// blowup; purgeWrite caps disk use. RESTORE to runTime / 0.02 / 0 before the
// production sweep, or every case will write hundreds of thousands of times.
writeControl    adjustableRunTime;

writeInterval   1e-06;

purgeWrite      20;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.3;

maxDeltaT       1e-05;

#include "../constant/freestreamProperties"

functions
{
    #include "postProcess"
}


