FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
#include "../constant/freestreamProperties"
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform $UInf;

boundaryField
{
    inlet       { type fixedValue; value uniform $UInf; }
    outlet      { type zeroGradient; }
    farfield    { type freestream; freestreamValue uniform $UInf; }
    body        { type noSlip; }
}


