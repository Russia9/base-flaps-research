FoamFile { version 2.0; format ascii; class dictionary; object snappyHexMeshDict; }

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    fuselage.stl
    {
        type triSurfaceMesh;
        scale 0.001;
        name fuselage;
    }
    stabilizers.stl
    {
        type triSurfaceMesh;
        scale 0.001;
        name stabilizers;
    }


    refinementCylinder
    {
        type searchableCylinder;
        point1 (-0.20 0.0 0.0);
        point2 (2.00 0.0 0.0);
        radius 0.36;
    }

    nearBodyCylinder
    {
        type searchableCylinder;
        point1 (-0.10 0.0 0.0);
        point2 (1.20 0.0 0.0);
        radius 0.12;
    }

    aftBaseCylinder
    {
        type searchableCylinder;
        point1 (0.76 0.0 0.0);
        point2 (0.92 0.0 0.0);
        radius 0.065;
    }

    noseCapCylinder
    {
        type searchableCylinder;
        point1 (-0.005 0.0 0.0);
        point2 ( 0.025 0.0 0.0);
        radius 0.025;
    }
};

castellatedMeshControls
{
    maxGlobalCells   10500000;
    maxLocalCells    1200000;
    minRefinementCells 8;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 4;
    resolveFeatureAngle 30;

    features
    (
        { file "fuselage.eMesh";    level 7; }
        { file "stabilizers.eMesh"; level 7; }
    );

    refinementSurfaces
    {
        fuselage { level (5 6); }
        stabilizers { level (5 6); }
    }

    refinementRegions
    {
        // Broad refinement from upstream of the nose through 1.5L downstream.
        refinementCylinder
        {
            mode inside;
            levels ((1E15 1));
        }

        // Stronger nested refinement around the body and immediate wake.
        nearBodyCylinder
        {
            mode inside;
            levels ((1E15 2));
        }

        // Local support for the thin fin/body-base junction.
        aftBaseCylinder
        {
            mode inside;
            levels ((1E15 3));
        }

        // Fine volume refinement wrapping the nose tip.
        noseCapCylinder
        {
            mode inside;
            levels ((1E15 5));
        }
    }

    locationInMesh (0.4 0.1 0.0);  // inside fluid, outside the 40 mm body radius
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch    3;
    tolerance       2.0;
    nSolveIter      55;
    nRelaxIter      6;
    nFeatureSnapIter 15;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    meshShrinker displacementMedialAxis;

    relativeSizes false;
    layers
    {
        fuselage    { nSurfaceLayers 15; }
        stabilizers { nSurfaceLayers 12; }
    }
    expansionRatio           1.25;
    firstLayerThickness      7.1e-7;

    maxFaceThicknessRatio    10.0;
    minThickness             3.5e-7;
    nSmoothThickness         5;
    nSmoothNormals           5;
    nSmoothSurfaceNormals    5;
    nGrow                    0;
    nBufferCellsNoExtrude    0;
    featureAngle             130;
    slipFeatureAngle         30;
    nRelaxIter               8;
    nRelaxedIter             50;
    nLayerIter               50;

    minMedialAxisAngle       90;
    maxThicknessToMedialRatio 0.6;
    nMedialAxisIter          10;   // optional, default is large; cap if slow
}

meshQualityControls
{
    maxNonOrtho          75;
    maxBoundarySkewness  20;
    maxInternalSkewness  8;
    maxConcave           80;
    minFlatness          0.5;
    minVol               1e-15;
    minTetQuality        -1e30;
    minArea              -1;
    minTwist             -1;
    minDeterminant       1e-9;
    minFaceWeight        -1;
    minVolRatio          -1;
    minTriangleTwist     -1;
    nSmoothScale         4;
    errorReduction       0.45;

    relaxed
    {
        maxNonOrtho          80;
        minDeterminant       1e-12;
        minFaceWeight        -1;
        minTetQuality        -1e30;
        minTwist             -1;
        minVolRatio          -1;
    }
}

writeFlags
(
    scalarLevels
);

mergeTolerance 1e-8;
